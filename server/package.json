{
  "name": "server",
  "version": "1.0.0",
  "description": "Taskflow Backend API",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "electron": "electron .",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "test": "echo \"Error: no test specified\" && exit 1",
    "compile": "tsc",
    "prepackage": "npm run compile && cp -R ../client/dist ./public",
    "package-mac": "npm run prepackage && electron-builder --mac"
  },
  "build": {
    "appId": "com.taskflow.app",
    "productName": "Taskflow",
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "main.cjs",
      "package.json",
      ".env"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
